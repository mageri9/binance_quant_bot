BOT_TOKEN=your_bot_token_here
ADMIN_IDS=[123456789,987654321]

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Rate limiting
RATE_LIMIT_CALLS=5
RATE_LIMIT_PERIOD=10

# Logging
LOG_LEVEL=INFO

# Nexus SRE (v2.0) Integration
NEXUS_APP_SECRET=your_nexus_app_secret_here
NEXUS_ENDPOINT_URL=http://nexus-webhook:8000/events/app
NEXUS_PROJECT_NAME=binance_quant_bot

# Database (оставьте пустым для локальной SQLite базы)
# Формат для PostgreSQL: postgresql://логин:пароль@хост:порт/имя_базы
DATABASE_URL=
OPTUNA_STORAGE_URL=postgresql+psycopg2://user:password@postgres:5432/marketmind

# Event-driven ML lifecycle
RETRAIN_POLL_SECONDS=900
RETRAIN_MIN_NEW_LABELS=200
RETRAIN_CONTROL_MAX_AGE_HOURS=168
MODEL_AUTO_PROMOTE_LEGACY=false
OPTUNA_SEED=42
OPTUNA_MIN_TRADES=20
OPTUNA_COMMISSION=0.0004
OPTUNA_SLIPPAGE=0.0002
OPTUNA_FUNDING_PER_TRADE=0.0001

# Trading Mode: paper | shadow | testnet | mainnet
# paper  — локальная симуляция с виртуальным портфелем
# shadow — только решения и уведомления, без ордеров
# testnet/mainnet — реальные приватные запросы Binance Futures
TRADING_MODE=testnet

# Binance API (обязательно только для testnet/mainnet)
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
BINANCE_PROXY=

# Model
MODEL_PATH=models/saved_models/lgbm_BTCUSDT_1h.pkl
PREDICTION_CONFIDENCE_THRESHOLD=0.55
